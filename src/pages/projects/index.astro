---
import TerminalLayout from '../../layouts/TerminalLayout.astro';
import LsOutput from '../../components/LsOutput.astro';
import { getCollection } from 'astro:content';
import type { LsEntryData } from '../../components/LsOutput.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf()
);

const currentPath = '~/projects';

const entries: LsEntryData[] = projects.map(p => ({
  type: 'file' as const,
  name: p.data.terminalFilename,
  href: `/projects/${p.id}/`,
  description: p.data.description,
  fileSize: p.data.fileSize ?? '—',
  date: p.data.startDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }),
}));
---

<TerminalLayout
  title={`projects/ — fer@portfolio`}
  description="Side projects and open source work"
  currentPath={currentPath}
>
  <div class="section-overview">
    <p>
      Personal projects built outside of work — things I wanted to exist and decided to build myself.
      From a <span class="overview-highlight">lost pets platform</span> with geospatial search and PDF poster generation
      to this <span class="overview-highlight">terminal portfolio</span> with a full REPL engine.
    </p>
  </div>
  <LsOutput entries={entries} path={currentPath} />
</TerminalLayout>

<style>
  .section-overview {
    padding: 0.75rem 1.5rem 0.25rem;
    border-left: 2px solid var(--primary-dim);
    margin: 0 1.5rem 0.5rem;
    color: var(--muted-light);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .overview-highlight {
    color: var(--white);
  }
</style>
