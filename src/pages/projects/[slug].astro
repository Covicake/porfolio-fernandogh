---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import CatLayout from '../../layouts/CatLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.id },
    props: p,
  }));
}

type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
const currentPath = `~/projects/${project.data.terminalFilename}`;
---

<CatLayout
  title={`${project.data.title} — fernando@portfolio`}
  description={project.data.description}
  currentPath={currentPath}
  filename={project.data.terminalFilename}
  backPath="/projects/"
  backLabel="projects/"
>
  <div class="page-layout">
    {project.data.coverImage && (
      <aside class="cover-aside">
        <div class="project-cover">
          <div class="project-cover__chrome">
            <span class="dot dot--red"></span>
            <span class="dot dot--yellow"></span>
            <span class="dot dot--green"></span>
            {project.data.liveUrl && (
              <span class="cover-url">{project.data.liveUrl.replace(/^https?:\/\//, '')}</span>
            )}
          </div>
          <div class="cover-img-wrap">
            <img src={project.data.coverImage} alt={`${project.data.title} screenshot`} loading="lazy" />
          </div>
        </div>
      </aside>
    )}
    <div class="page-content">
      <Content />
      {(project.data.repoUrl || project.data.liveUrl) && (
        <div class="project-links">
          {project.data.repoUrl && (
            <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer">[repo]</a>
          )}
          {project.data.liveUrl && (
            <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer">[live]</a>
          )}
        </div>
      )}
    </div>
  </div>
</CatLayout>

<style>
  .page-layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .cover-aside {
    flex: 0 0 33%;
  }

  .page-content {
    flex: 1;
    min-width: 0;
  }

  .project-cover {
    border: 1px solid var(--primary-dim);
    border-radius: 6px;
    overflow: hidden;
  }

  .project-cover__chrome {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.75rem;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--primary-dim);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot--red    { background: #ff5f57; }
  .dot--yellow { background: #ffbd2e; }
  .dot--green  { background: #28c840; }

  .cover-url {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cover-img-wrap {
    position: relative;
    line-height: 0;
  }

  .cover-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.04) 2px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
  }

  .cover-img-wrap img {
    display: block;
    width: 100%;
    height: auto;
    filter: saturate(0.88) contrast(1.04) brightness(0.95);
  }

  .project-links {
    margin-top: 1rem;
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
  }
  .project-links a {
    color: var(--primary);
  }

  @media (max-width: 640px) {
    .page-layout {
      flex-direction: column;
    }
    .cover-aside {
      flex: none;
      width: 100%;
    }
  }
</style>
