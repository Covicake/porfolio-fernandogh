---
import TerminalLayout from '../../layouts/TerminalLayout.astro';
import LsOutput from '../../components/LsOutput.astro';
import { getCollection } from 'astro:content';
import type { LsEntryData } from '../../components/LsOutput.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const currentPath = '~/blog';

const entries: LsEntryData[] = posts.map(post => ({
  type: 'file' as const,
  name: post.data.terminalFilename ?? `${post.id}.md`,
  href: `/blog/${post.id}/`,
  description: post.data.description,
  fileSize: post.data.fileSize ?? '—',
  date: post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }),
}));
---

<TerminalLayout
  title={`blog/ — fer@portfolio`}
  description="Writing and notes"
  currentPath={currentPath}
>
  <LsOutput entries={entries} path={currentPath} />
</TerminalLayout>
