---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import CatLayout from '../../layouts/CatLayout.astro';

export async function getStaticPaths() {
  const experience = await getCollection('experience');
  return experience.map(e => ({
    params: { slug: e.id },
    props: e,
  }));
}

type Props = CollectionEntry<'experience'>;

const entry = Astro.props;
const { Content } = await render(entry);
const currentPath = `~/experience/${entry.data.terminalFilename}`;
---

<CatLayout
  title={`${entry.data.role} @ ${entry.data.company} — fernando@portfolio`}
  description={entry.data.description}
  currentPath={currentPath}
  filename={entry.data.terminalFilename}
  backPath="/experience/"
  backLabel="experience/"
>
  <div class="page-layout">
    {entry.data.coverImage && (
      <aside class="cover-aside">
        <div class="entry-cover">
          <div class="entry-cover__chrome">
            <span class="dot dot--red"></span>
            <span class="dot dot--yellow"></span>
            <span class="dot dot--green"></span>
            <span class="cover-label">{entry.data.company}</span>
          </div>
          <div class="cover-img-wrap">
            <img src={entry.data.coverImage} alt={`${entry.data.company} screenshot`} loading="lazy" />
          </div>
        </div>
      </aside>
    )}
    <div class="page-content">
      <Content />
    </div>
  </div>
</CatLayout>

<style>
  .page-layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .cover-aside {
    flex: 0 0 33%;
  }

  .page-content {
    flex: 1;
    min-width: 0;
  }

  .entry-cover {
    border: 1px solid var(--primary-dim);
    border-radius: 6px;
    overflow: hidden;
  }

  .entry-cover__chrome {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.75rem;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--primary-dim);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot--red    { background: #ff5f57; }
  .dot--yellow { background: #ffbd2e; }
  .dot--green  { background: #28c840; }

  .cover-label {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .cover-img-wrap {
    position: relative;
    line-height: 0;
  }

  .cover-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.04) 2px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
  }

  .cover-img-wrap img {
    display: block;
    width: 100%;
    height: auto;
    filter: saturate(0.88) contrast(1.04) brightness(0.95);
  }

  @media (max-width: 640px) {
    .page-layout {
      flex-direction: column;
    }
    .cover-aside {
      flex: none;
      width: 100%;
    }
  }
</style>
