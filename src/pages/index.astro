---
import TerminalLayout from '../layouts/TerminalLayout.astro';
import AsciiArt from '../components/AsciiArt.astro';
import LsOutput from '../components/LsOutput.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import type { LsEntryData } from '../components/LsOutput.astro';

const currentPath = '~';

const entries: LsEntryData[] = [
  { type: 'dir',  name: 'projects',    href: '/projects/',   description: 'side projects & open source',  fileSize: '4.0K', date: 'Jan 2024' },
  { type: 'dir',  name: 'experience',  href: '/experience/', description: 'work history',                  fileSize: '4.0K', date: 'Jan 2024' },
  { type: 'dir',  name: 'education',   href: '/education/',  description: 'degrees & courses',             fileSize: '4.0K', date: 'Jan 2024' },
  { type: 'file', name: 'bio.md',      href: '/bio/',        description: 'who I am',                      fileSize: '2.4K', date: 'Jan 2024' },
  { type: 'file', name: 'tech_stack.md', href: '/tech-stack/', description: 'languages & tools',           fileSize: '1.6K', date: 'Jan 2024' },
  { type: 'file', name: 'contact.md',  href: '/contact/',    description: 'email, github, linkedin',       fileSize: '0.8K', date: 'Jan 2024' },
];
---

<TerminalLayout title={SITE_TITLE} description={SITE_DESCRIPTION} currentPath={currentPath}>
  <AsciiArt />
  <LsOutput entries={entries} path={currentPath} />
</TerminalLayout>
